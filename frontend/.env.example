# GeoQuest Environment Variables
# Copy to .env.local and fill in values

# Soroban RPC endpoint
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Stellar network config
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_NETWORK_NAME=testnet

# Deployed contract addresses (update after deployment)
VITE_QUEST_REGISTRY_CONTRACT=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
VITE_REWARD_TOKEN_CONTRACT=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
VITE_CLAIM_MANAGER_CONTRACT=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
VITE_IMPACT_VAULT_CONTRACT=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
VITE_BOUNTY_ESCROW_CONTRACT=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Verification API URL
VITE_VERIFICATION_API_URL=http://localhost:8787

# Admin wallet addresses (comma-separated)
VITE_ADMIN_WALLETS=
